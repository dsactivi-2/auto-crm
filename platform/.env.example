# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic
ANTHROPIC_API_KEY=your-anthropic-api-key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Encryption key for CRM credentials (generate with: openssl rand -hex 32)
CREDENTIALS_ENCRYPTION_KEY=your-64-char-hex-key

# CRM (optional, default: https://crm.job-step.com)
CRM_URL=https://crm.job-step.com

# Playwright Service (optional, default: http://playwright:3001)
PLAYWRIGHT_SERVICE_URL=http://playwright:3001

# Log-Level für Playwright Service (debug|info|warn|error|fatal)
LOG_LEVEL=info

# ── Lizenz ────────────────────────────────────────────────
# Generiere mit: node scripts/generate-license.js
LICENSE_KEY=your-license-key
LICENSE_SECRET=your-license-secret-min-32-chars

# Optional: Remote License-Server für Kill-Switch
# LICENSE_SERVER_URL=https://your-license-server.com
